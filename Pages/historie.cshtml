@page
@model RagnarockGasolin.Pages.historieModel
@{
}

<div class="container-fluid  " >
    <div id="carouselExampleCaptions" class="carousel slide">
        <div class="carousel-indicators">
            <button type="button" data-bs-target="#carouselExampleCaptions" data-bs-slide-to="0" class="active" aria-current="true" aria-label="Slide 1"></button>
            <button type="button" data-bs-target="#carouselExampleCaptions" data-bs-slide-to="1" aria-label="Slide 2"></button>
            <button type="button" data-bs-target="#carouselExampleCaptions" data-bs-slide-to="2" aria-label="Slide 3"></button>
            <button type="button" data-bs-target="#carouselExampleCaptions" data-bs-slide-to="3" aria-label="Slide 4"></button>
            <button type="button" data-bs-target="#carouselExampleCaptions" data-bs-slide-to="3" aria-label="Slide 5"></button>

        </div>
        <div class="carousel-inner ">
            <div class="carousel-item active">
                <img src="~/images/gif.gif" class="d-block w-100 vw-100 carousel-img-responsive" alt="...">
                <div class="carousel-caption d-none d-md-block">
                    <h5>Lærer om deres vidunderlig rejse! !</h5>
                    <p><a href="/historyaboutband1#album" class="stretched-link text-decoration-none d-inline-block rounded-2 text-white px-2 py-1">mere end 400 concerter verden over og hele 10 albums .</a>
                </div>
            </div>
            <div class="carousel-item">
                <img src="~/images/startup.jpg" class="carousel-img-responsive d-block w-100 vw-100" alt="...">
                <div class="carousel-caption d-none d-md-block">
                    <h5>Fra bunden til top </h5>
                    <p><a href="/historyaboutband1#Historieomgasolin" class="stretched-link text-decoration-none d-inline-block rounded-2 text-white px-2 py-1">Tryk og læs om Gasolin's historie og hvordan de fra bunden har nået toppen.</a>
                </div>
            </div>
            <div class="carousel-item">
                <img src="~/images/de 4.jpg" class="carousel-img-responsive d-block w-100 vw-100" alt="...">
                <div class="carousel-caption d-none d-md-block">
                    <h5>Dansk stolthed </h5>
                    <p> <a href="/historyaboutband1#danskmusik" class="stretched-link text-decoration-none d-inline-block rounded-2 text-white px-2 py-1">Læs mere om hvordan de 4 legender har ændret dansk musik.</a>
                </div>
            </div>
            <div class="carousel-item">
                <img src="~/images/splittet.png" class="carousel-img-responsive d-block w-100 vw-100" alt="...">
                <div class="carousel-caption d-none d-md-block">
                    <h5>Hver succes har en ende  </h5>
                    <p> <a href="/historyaboutband1#endenforgasolin" class="stretched-link text-decoration-none d-inline-block rounded-2 text-white px-2 py-1">efter 9 års succes og hårdt arbejde.</a>
                </div>
            </div>
            <div class="carousel-item">
                <img src="~/images/interview.gif" class="carousel-img-responsive d-block w-100 vw-100" alt="...">
                <div class="carousel-caption d-none d-md-block">
                    <h5>Se interviewet med Gasolin  </h5>
                    <p> <a href="/historyaboutband1#interview" class="stretched-link text-decoration-none d-inline-block rounded-2 text-white px-2 py-1"> </a>
                </div>
            </div>
        </div>
        <button class="carousel-control-prev" type="button" data-bs-target="#carouselExampleCaptions" data-bs-slide="prev">
            <span class="carousel-control-prev-icon" aria-hidden="true"></span>
            <span class="visually-hidden">Previous</span>
        </button>
        <button class="carousel-control-next" type="button" data-bs-target="#carouselExampleCaptions" data-bs-slide="next">
            <span class="carousel-control-next-icon" aria-hidden="true"></span>
            <span class="visually-hidden">Next</span>
        </button>
    </div>


</div>
